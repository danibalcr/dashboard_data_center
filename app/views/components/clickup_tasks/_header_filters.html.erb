<div class="filters-bar">
  <%= link_to "All", root_path(merged_params({ task_filter: "all" })), class: "filter-btn #{'filter-btn-active' if @task_filter == 'all'}" %>

  <%= link_to "Overdue", root_path(merged_params({ task_filter: "overdue" })), class: "filter-btn #{'filter-btn-active' if @task_filter == 'overdue'}" %>

  <%= link_to "Today", root_path(merged_params({ task_filter: "today" })), class: "filter-btn #{'filter-btn-active' if @task_filter == 'today'}" %>

  <%= link_to "Assigned to Me", root_path(merged_params({ task_filter: "assigned_to_me" })), class: "filter-btn #{'filter-btn-active' if @task_filter == 'assigned_to_me'}" %>

  <%= render "components/clickup_tasks/dropdown_by_status" %>
</div>

<style>
  .filters-bar {
    height: 40px;
    display: flex;
    align-items:center;
    gap: 10px;
    padding-top: 18px;
    padding-bottom: 15px;
    padding-left: 20px;
    padding-right: 20px;
    border-bottom: 1px solid #ccc;
  }

  .filter-btn {
    text-align: center;
    min-width: 50px;
    padding: 8px;
    border-radius: 5px;
    background-color: #eef3f6;
    color: #333;
    text-decoration: none;
  }

  .filter-btn-active {
    background-color: #124e9f; color: white;
  }
</style>
